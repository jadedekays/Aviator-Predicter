rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['phoneNumber', 'password', 'createdAt']) &&
             data.phoneNumber is string && data.phoneNumber.size() >= 9 &&
             data.password is string && data.password.size() >= 4 &&
             data.createdAt is timestamp;
    }

    function isCreator(phone) {
      return phone == "779208037";
    }

    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == "jadedekays@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /stats/{docId} {
      allow read: if true;
      allow write: if true; // Allow increments/decrements
    }

    match /visitors/{visitorId} {
      allow read: if true;
      allow write: if true;
    }

    match /users/{phoneNumber} {
      allow get: if true;
      allow list: if true;
      
      allow create: if true;
      
      allow update: if true;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
