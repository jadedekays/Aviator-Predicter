rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['phoneNumber', 'password', 'createdAt']) &&
             data.phoneNumber is string && data.phoneNumber.size() >= 9 &&
             data.password is string && data.password.size() >= 4 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{phoneNumber} {
      // Allow anyone to check if a user exists or create a new one (registration)
      // In a real app, we'd use Firebase Auth, but here we are using a custom phone+pass system
      // stored in Firestore for simplicity as per user request.
      allow get: if true;
      allow create: if isValidUser(request.resource.data) && request.resource.data.phoneNumber == phoneNumber;
      
      // Only allow updates if they know the current password (handled in app logic)
      // but for rules, we just ensure schema validity.
      allow update: if isValidUser(request.resource.data);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
